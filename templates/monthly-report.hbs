<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;font-family:Arial,sans-serif;background-color:#f4f4f4;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f4f4;">
    <tr>
      <td align="center" style="padding:20px 0;">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff;max-width:600px;">

          <!-- Header -->
          <tr>
            <td style="background-color:#4a90e2;color:#ffffff;padding:30px 20px;text-align:center;">
              <h1 style="margin:0;font-size:24px;font-weight:bold;">📊 {{monthLabel}} Newsletter Report</h1>
              <p style="margin:10px 0 0 0;font-size:16px;color:#e6f2ff;">Your monthly performance summary</p>
              {{#if reportUrl}}
              <div style="margin:18px 0 0 0;">
                <a href="{{reportUrl}}" style="display:inline-block;background-color:#ffffff;color:#4a90e2;text-decoration:none;padding:10px 18px;border-radius:20px;font-weight:bold;font-size:14px;">
                  View full report in dashboard
                </a>
              </div>
              {{/if}}
            </td>
          </tr>

          <!-- Summary grid -->
          <tr>
            <td style="padding:20px;background-color:#f8f9fa;">
              <h3 style="margin:0 0 10px 0;font-size:18px;color:#333;">The month at a glance</h3>
              <table width="100%" cellpadding="8" cellspacing="0" border="0">
                {{#each summaryStats}}
                <tr>
                  <td style="padding:6px 0;color:#666;font-size:14px;width:55%;">{{this.label}}</td>
                  <td style="padding:6px 0;color:#222;font-size:14px;font-weight:bold;">{{this.value}}</td>
                </tr>
                {{/each}}
              </table>
            </td>
          </tr>

          <!-- Subscriber growth -->
          <tr>
            <td style="padding:20px;">
              <h3 style="margin:0 0 12px 0;font-size:18px;color:#333;border-bottom:2px solid #e9ecef;padding-bottom:8px;">Subscriber growth</h3>
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="font-size:14px;color:#666;padding:4px 0;">Start of month</td>
                  <td style="font-size:14px;color:#222;font-weight:bold;text-align:right;">{{subscriberGrowth.startCount}}</td>
                </tr>
                <tr>
                  <td style="font-size:14px;color:#666;padding:4px 0;">End of month</td>
                  <td style="font-size:14px;color:#222;font-weight:bold;text-align:right;">{{subscriberGrowth.endCount}}</td>
                </tr>
                <tr>
                  <td style="font-size:14px;color:#666;padding:4px 0;border-top:1px solid #e9ecef;">Net change</td>
                  <td style="font-size:16px;color:{{subscriberGrowth.color}};font-weight:bold;text-align:right;border-top:1px solid #e9ecef;">{{subscriberGrowth.netChange}} ({{subscriberGrowth.growthRate}})</td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Top links -->
          {{#if hasTopLinks}}
          <tr>
            <td style="padding:20px;background-color:#f8f9fa;">
              <h3 style="margin:0 0 12px 0;font-size:18px;color:#333;border-bottom:2px solid #e9ecef;padding-bottom:8px;">Top 5 links this month</h3>
              <table width="100%" cellpadding="6" cellspacing="0" border="0">
                {{#each topLinks}}
                <tr>
                  <td style="font-size:16px;width:34px;text-align:center;">{{this.rank}}</td>
                  <td style="font-size:13px;color:#222;padding:6px 0;">
                    <a href="{{this.url}}" style="color:#4a90e2;text-decoration:none;">{{this.label}}</a>
                    <div style="font-size:11px;color:#999;">across {{this.issueCount}} issue(s)</div>
                  </td>
                  <td style="font-size:14px;color:#222;font-weight:bold;text-align:right;white-space:nowrap;">{{this.clicks}} clicks</td>
                </tr>
                {{/each}}
              </table>
            </td>
          </tr>
          {{/if}}

          <!-- Insights -->
          {{#if hasInsights}}
          <tr>
            <td style="padding:20px;">
              <h3 style="margin:0 0 12px 0;font-size:18px;color:#333;border-bottom:2px solid #e9ecef;padding-bottom:8px;">Insights &amp; recommendations</h3>
              {{#each insights}}
              <div style="border:1px solid #e9ecef;border-left:5px solid {{this.color}};padding:12px;margin-bottom:10px;border-radius:6px;">
                <div style="font-size:12px;text-transform:uppercase;letter-spacing:0.6px;color:#666;margin-bottom:6px;">{{this.type}} • {{this.severity}}</div>
                <div style="font-size:14px;color:#222;font-weight:bold;margin-bottom:4px;">{{this.title}}</div>
                <div style="font-size:13px;color:#444;">{{this.detail}}</div>
                {{#if this.recommendation}}
                <div style="font-size:13px;color:#1a6dbb;margin-top:6px;">→ {{this.recommendation}}</div>
                {{/if}}
              </div>
              {{/each}}
            </td>
          </tr>
          {{/if}}

          <!-- Best performers -->
          <tr>
            <td style="padding:20px;background-color:#f8f9fa;">
              <h3 style="margin:0 0 12px 0;font-size:18px;color:#333;border-bottom:2px solid #e9ecef;padding-bottom:8px;">Best performers</h3>
              <table width="100%" cellpadding="6" cellspacing="0" border="0">
                <tr>
                  <td style="font-size:13px;color:#666;width:45%;">Best open rate</td>
                  <td style="font-size:13px;color:#222;">{{bestIssue.openSubject}} <strong>({{bestIssue.openValue}})</strong></td>
                </tr>
                <tr>
                  <td style="font-size:13px;color:#666;">Best click rate</td>
                  <td style="font-size:13px;color:#222;">{{bestIssue.clickSubject}} <strong>({{bestIssue.clickValue}})</strong></td>
                </tr>
                <tr>
                  <td style="font-size:13px;color:#666;">Most clicks</td>
                  <td style="font-size:13px;color:#222;">{{bestIssue.clicksSubject}} <strong>({{bestIssue.clicksValue}})</strong></td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Per-issue breakdown -->
          <tr>
            <td style="padding:20px;">
              <h3 style="margin:0 0 12px 0;font-size:18px;color:#333;border-bottom:2px solid #e9ecef;padding-bottom:8px;">Issue-by-issue</h3>
              <table width="100%" cellpadding="6" cellspacing="0" border="0" style="border-collapse:collapse;">
                <tr style="background-color:#f1f3f5;">
                  <td style="font-size:12px;color:#666;padding:8px 6px;">Issue</td>
                  <td style="font-size:12px;color:#666;padding:8px 6px;text-align:right;">Open</td>
                  <td style="font-size:12px;color:#666;padding:8px 6px;text-align:right;">Click</td>
                  <td style="font-size:12px;color:#666;padding:8px 6px;text-align:right;">Clicks</td>
                </tr>
                {{#each issues}}
                <tr style="border-top:1px solid #e9ecef;">
                  <td style="font-size:12px;color:#222;padding:8px 6px;">#{{this.issueNumber}} {{this.subject}}</td>
                  <td style="font-size:12px;color:#222;padding:8px 6px;text-align:right;">{{this.openRate}}</td>
                  <td style="font-size:12px;color:#222;padding:8px 6px;text-align:right;">{{this.clickRate}}</td>
                  <td style="font-size:12px;color:#222;padding:8px 6px;text-align:right;">{{this.clicks}}</td>
                </tr>
                {{/each}}
              </table>
            </td>
          </tr>

          {{#if hasAbTests}}
          <!-- A/B tests -->
          <tr>
            <td style="padding:20px;">
              <h3 style="margin:0 0 12px 0;font-size:18px;color:#333;border-bottom:2px solid #e9ecef;padding-bottom:8px;">A/B tests</h3>
              {{#each abTests}}
              <table width="100%" cellpadding="6" cellspacing="0" border="0" style="border-collapse:collapse;margin-bottom:16px;">
                <tr>
                  <td style="font-size:13px;color:#222;font-weight:bold;padding:4px 6px;">#{{this.issueNumber}} {{this.subject}}</td>
                  <td style="font-size:12px;color:#666;padding:4px 6px;text-align:right;">{{this.dimensionLabel}} · {{this.outcome}}</td>
                </tr>
                <tr style="background-color:#f1f3f5;">
                  <td style="font-size:12px;color:#666;padding:6px;">Variant</td>
                  <td style="font-size:12px;color:#666;padding:6px;text-align:right;">Open / Click</td>
                </tr>
                {{#each this.variants}}
                <tr style="border-top:1px solid #e9ecef;">
                  <td style="font-size:12px;color:#222;padding:6px;">{{#if this.isWinner}}🏆 {{/if}}Variant {{this.variantId}} — {{this.label}}</td>
                  <td style="font-size:12px;color:#222;padding:6px;text-align:right;">{{this.openRate}} / {{this.clickRate}}</td>
                </tr>
                {{/each}}
                <tr>
                  <td colspan="2" style="font-size:11px;color:#999;padding:6px;">Win metric: {{this.winMetricLabel}} · Lift: {{this.liftText}} · {{this.significanceText}}</td>
                </tr>
              </table>
              {{/each}}
            </td>
          </tr>
          {{/if}}

          <!-- Footer -->
          <tr>
            <td style="padding:20px;text-align:center;border-top:1px solid #e9ecef;">
              <p style="margin:0;font-size:12px;color:#999;">Generated {{generatedDate}}</p>
              {{#if reportUrl}}
              <p style="margin:8px 0 0 0;font-size:12px;"><a href="{{reportUrl}}" style="color:#4a90e2;text-decoration:none;">Open this report in your dashboard</a></p>
              {{/if}}
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
