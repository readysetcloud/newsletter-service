{
  "name": "newsletter-service",
  "version": "1.0.0",
  "description": "Service to send a newsletter",
  "author": "allenheltondev",
  "type": "module",
  "license": "ISC",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "lint:ui": "npm --prefix dashboard-ui run lint",
    "lint:all": "npm run lint && npm run lint:ui",
    "coverage": "c8 npm test",
    "test:rust": "cargo test --workspace",
    "lint:rust": "cargo clippy --workspace --all-targets",
    "lint:rust:fix": "cargo clippy --workspace --all-targets --fix --allow-dirty --allow-staged",
    "fmt:rust": "cargo fmt --all -- --check",
    "fmt:rust:fix": "cargo fmt --all"
  },
  "workspaces": [
    "dashboard-ui"
  ],
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.31.0",
    "@aws-lambda-powertools/parameters": "^2.31.0",
    "@aws-sdk/client-sesv2": "^3.1007.0",
    "@github-docs/frontmatter": "^1.3.1",
    "aws-jwt-verify": "^5.1.1",
    "handlebars": "^4.7.8",
    "maxmind": "^5.0.5",
    "octokit": "^5.0.5",
    "showdown": "^2.1.0",
    "stripe": "^20.4.1",
    "ulid": "^3.0.2",
    "zlib": "^1.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1007.0",
    "@aws-sdk/client-cloudwatch": "^3.1007.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1007.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/client-eventbridge": "^3.1007.0",
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/client-scheduler": "^3.1007.0",
    "@aws-sdk/client-secrets-manager": "^3.1007.0",
    "@aws-sdk/client-sfn": "^3.1007.0",
    "@aws-sdk/client-sqs": "^3.1007.0",
    "@aws-sdk/client-ssm": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.3.0",
    "c8": "^11.0.0",
    "clipboardy": "^5.3.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "sharp": "^0.34.5"
  }
}
